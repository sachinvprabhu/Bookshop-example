{
  "name": "bookshop",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-bookshop-ui": "cds watch --open bookshop.bookshopui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy bookshop --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-manage-authors": "cds watch --open bookshop.manageauthors/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-customers-geo": "cds watch --open bookshop.customersgeo/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "auth": {
        "strategy": "mock",
        "users": {
          "manager@company.com": {
            "password": "strong-password",
            "roles": [
              "Manager_Role"
            ]
          },
          "employee@company.com": {
            "password": "strong-password",
            "roles": [
              "Employee_Role"
            ]
          }
        }
      },
      "connectivity": true,
      "destinations": true,
      "html5-repo": true,
      "application-logging": true,
      "northwind": {
        "kind": "odata",
        "model": "srv/external/northwind",
        "credentials": {
          "url": "https://services.odata.org/v4/northwind/northwind.svc"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/bookshop-ui",
    "app/manage-authors"
  ]
}
