{
  "_version": "1.83.0",
  "sap.app": {
    "id": "bookshop.customersgeo",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "6bec7d42-60ad-4360-a703-cc1e0cd2c047"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/bookshopService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "CustomerGeo-display": {
          "semanticObject": "CustomerGeo",
          "action": "display",
          "title": "{{CustomerGeo-display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "resourceRoots": {
      "sap.ui.geomap": "./resources/sap/ui/geomap"
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "bookshop.customersgeo.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "bookshop.customersgeo.view",
        "async": true,
        "viewPath": "bookshop.customersgeo.view"
      },
      "routes": [
        {
          "name": "RouteRootView",
          "pattern": ":?query:",
          "target": [
            "TargetRootView"
          ]
        }
      ],
      "targets": {
        "TargetRootView": {
          "id": "RootView",
          "name": "RootView"
        }
      }
    },
    "rootView": {
      "viewName": "bookshop.customersgeo.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "bookshop"
  }
}
